// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  MENTOR
  ADMIN
}

model User {
  id              String           @id @default(uuid())
  email           String           @unique
  password        String?
  avatar          String?
  name            String
  role            Role
  isVerified      Boolean          @default(false)
  otp             String?
  otpExpiry       DateTime?
  nifesZone       String?
  nifesSchool     String?
  unit            String?
  wing            String?
  courseOfStudy   String?
  level           String?
  googleId        String?          @unique
  appleId         String?          @unique
  authProvider    String           @default("local") // "local" | "google" | "apple"
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  mentorSessions  Session[]        @relation("MentorSessions")
  userSessions    Session[]        @relation("UserSessions")
  savedScriptures SavedScripture[]
  mentorProfile   MentorProfile?
  attendances     Attendance[]
}

model AnchorWord {
  id                 String   @id @default(uuid())
  date               DateTime @unique
  scripture          String
  scriptureReference String
  reflection         String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Session {
  id        String   @id @default(uuid())
  mentorId  String
  userId    String
  date      DateTime
  topic     String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mentor User @relation("MentorSessions", fields: [mentorId], references: [id], onDelete: Cascade)
  user   User @relation("UserSessions", fields: [userId], references: [id], onDelete: Cascade)
}

model SavedScripture {
  id                 String   @id @default(uuid())
  userId             String
  scripture          String
  scriptureReference String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum FocusArea {
  ACADEMICS
  SPIRITUAL
  CAREER
  MENTAL_HEALTH
}

enum ProgramType {
  SEMINAR
  CAMPING
  CONFERENCE
  BIBLE_STUDY_WEEKEND
  OTHER
}

model Program {
  id             String       @id @default(uuid())
  title          String
  type           ProgramType
  description    String?
  attendanceCode String       @unique
  startTime      DateTime
  endTime        DateTime
  createdBy      String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  attendances Attendance[]

  @@map("programs")
}

model Attendance {
  id        String   @id @default(uuid())
  userId    String
  programId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([userId, programId])
  @@map("attendances")
}

model MentorProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  // Step 1 - Verification
  fellowshipPosition  String?
  campus              String?
  verificationFileUrl String?
  verificationStatus  String  @default("pending") // pending | approved | rejected

  // Step 2 - Profile Setup
  profilePhotoUrl String?
  bio             String?
  focusArea       FocusArea?

  // Step 3 - Availability
  isAvailable        Boolean  @default(false)
  availableDays      String[] // ["Monday", "Tuesday"]
  availableTimeStart String? // "08:30pm"
  availableTimeEnd   String? // "06:00pm"

  onboardingStep       Int     @default(1) // tracks current step
  isOnboardingComplete Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
